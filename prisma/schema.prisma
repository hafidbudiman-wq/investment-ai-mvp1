generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportPeriodType {
  Q1
  H1
  Q3
  FY
  MONTHLY
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum StatementType {
  INCOME_STATEMENT
  BALANCE_SHEET
  CASH_FLOW
}

model Company {
  id             String               @id @default(cuid())
  ticker         String               @unique
  name           String
  sector         String?
  subsector      String?
  ipoYear        Int?
  currency       String               @default("IDR")
  fiscalYearEnd  Int                  @default(12)
  reports        FinancialReport[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model FinancialReport {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year        Int
  periodType  ReportPeriodType
  periodEnd   DateTime
  audited     Boolean          @default(false)
  sourceFile  String?
  status      ReviewStatus     @default(DRAFT)
  entries     FinancialEntry[]
  warnings    DataWarning[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@unique([companyId, year, periodType])
  @@index([companyId, periodEnd])
}

model CanonicalAccount {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  statementType StatementType
  entries       FinancialEntry[]
  mappings      AccountMapping[]
}

model FinancialEntry {
  id                 String           @id @default(cuid())
  reportId           String
  report             FinancialReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  canonicalAccountId String
  canonicalAccount   CanonicalAccount @relation(fields: [canonicalAccountId], references: [id])
  reportedLabel      String?
  value              Decimal          @db.Decimal(24, 4)
  scale              Int              @default(1)
  currency           String           @default("IDR")
  isVerified         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  @@unique([reportId, canonicalAccountId])
}

model AccountMapping {
  id                 String           @id @default(cuid())
  sourceLabel        String           @unique
  canonicalAccountId String
  canonicalAccount   CanonicalAccount @relation(fields: [canonicalAccountId], references: [id])
  confidence         Float?
  createdAt          DateTime         @default(now())
}

model DataWarning {
  id         String          @id @default(cuid())
  reportId   String
  report     FinancialReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  code       String
  message    String
  severity   String
  resolved   Boolean         @default(false)
  createdAt  DateTime        @default(now())
}
